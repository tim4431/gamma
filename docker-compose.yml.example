services:
  gamma:
    container_name: gamma
    image: ghcr.io/tim4431/gamma:latest
    build: .
    ports:
      - "9001:9001"
    volumes:
      - gamma-data:/data
    # Secrets and AI settings live in .env (copy .env.example → .env)
    env_file:
      - path: .env
        required: false
    restart: unless-stopped

volumes:
  gamma-data:
