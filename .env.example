# Gamma configuration — copy to .env and edit.
# docker-compose loads this automatically; for bare-metal: set -a; source .env

# --- Bootstrap admin account (created on first container start;
#     password is re-applied on every restart) ---
GAMMA_ADMIN_USER=admin
GAMMA_ADMIN_PASSWORD=change-me

# --- Open-access lookup (optional but recommended) ---
# When a DOI link points at a paywalled/bot-blocked publisher page, Gamma asks
# the Unpaywall API for a legal open-access copy (often the arXiv version).
# Unpaywall requires a real contact email — example.com addresses are rejected.
#GAMMA_CONTACT_EMAIL=you@example.org

# --- AI chat defaults (optional) ---
# API keys are NOT set here: each user adds their own key in the app
# (account menu → "AI providers & keys…"); it is stored server-side for that
# user and never sent back to the browser. The variables below only set
# instance-wide DEFAULTS that users inherit until they override them in the
# same dialog:
#   anthropic — Anthropic Messages API; also works with DeepSeek, Kimi, GLM, ...
#   openai    — OpenAI Chat Completions API; also works with OpenAI-compatible servers
#GAMMA_AI_ANTHROPIC_BASE_URL=https://api.anthropic.com
#GAMMA_AI_OPENAI_BASE_URL=https://api.openai.com

# Default model switcher list, as comma-separated "provider:model" entries.
# The FIRST entry is the default model. Mixing providers is fine.
#GAMMA_AI_MODELS=openai:gpt-5.5,anthropic:claude-haiku-4-5-20251001

# Example: DeepSeek via its Anthropic-compatible endpoint
#GAMMA_AI_ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
#GAMMA_AI_MODELS=anthropic:deepseek-v4-flash

# Legacy names (GAMMA_AI_PROVIDER, GAMMA_AI_BASE_URL, GAMMA_AI_MODEL, and the
# ANTHROPIC_BASE_URL alias) still work for the base URL / model defaults.
# Key variables (GAMMA_AI_*_API_KEY, GAMMA_AI_API_KEY, ANTHROPIC_AUTH_TOKEN)
# are ignored — keys are per-user, set in the GUI.
