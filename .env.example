# Gamma configuration — copy to .env and edit.
# docker-compose loads this automatically; for bare-metal: set -a; source .env

# --- Bootstrap admin account (created on first container start;
#     password is re-applied on every restart) ---
GAMMA_ADMIN_USER=admin
GAMMA_ADMIN_PASSWORD=change-me

# --- AI chat (optional; leave unset to disable the chat panel) ---
# Wire protocol: "anthropic" (default) or "openai".
#   anthropic — Anthropic Messages API; also works with DeepSeek, Kimi, GLM, ...
#   openai    — OpenAI Chat Completions API; also works with OpenAI-compatible servers
#GAMMA_AI_PROVIDER=anthropic
#GAMMA_AI_API_KEY=sk-...

# Base URL and model default per provider:
#   anthropic → https://api.anthropic.com  / claude-haiku-4-5-20251001
#   openai    → https://api.openai.com     / gpt-4o-mini
#GAMMA_AI_BASE_URL=
#GAMMA_AI_MODEL=

# Extra models offered in the chat panel's model switcher (comma-separated;
# the default model is always included).
#GAMMA_AI_MODELS=claude-haiku-4-5-20251001,claude-sonnet-5

# Example: DeepSeek via its Anthropic-compatible endpoint
#GAMMA_AI_PROVIDER=anthropic
#GAMMA_AI_API_KEY=sk-...
#GAMMA_AI_BASE_URL=https://api.deepseek.com/anthropic
#GAMMA_AI_MODEL=deepseek-v4-flash

# Example: OpenAI
#GAMMA_AI_PROVIDER=openai
#GAMMA_AI_API_KEY=sk-...
